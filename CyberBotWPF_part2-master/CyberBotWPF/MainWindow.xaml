<Window x:Class="CyberBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot Companion" Height="650" Width="900" 
        WindowStartupLocation="CenterScreen" Background="#0D1117">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#0D1117"/>
        <SolidColorBrush x:Key="PanelBg" Color="#161B22"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>
        <SolidColorBrush x:Key="TextMain" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#00E5FF"/>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="TitleLabel" Text="CyberG Hub" Foreground="{StaticResource AccentCyan}" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Local Security Sandbox" Foreground="#8B949E" FontSize="11" Margin="0,4,0,20"/>
                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                    <TextBlock Text="SESSION PARAMETERS" Foreground="#8B949E" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="MemoryUserLabel" Text="👤 Name: Guest" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,4,0,4"/>
                    <TextBlock x:Name="MemoryTopicLabel" Text="⭐ Interest: –" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,4,0,4"/>
                    <TextBlock x:Name="MemorySentimentLabel" Text="💬 Mood: –" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,4,0,4"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="Clear Chat History" Click="ClearChat_Click" Background="#21262D" Foreground="#F85149" BorderBrush="{StaticResource BorderColor}" Padding="8,6,8,6" Margin="0,0,0,8" FontWeight="Bold"/>
                    <Button Content="Terminate Session" Click="Exit_Click" Background="#21262D" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="8,6,8,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,10">
                <ItemsControl x:Name="TopicButtons">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Click="TopicButton_Click" Background="#21262D" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Margin="0,0,6,6" Padding="10,5,10,5"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,15">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="InputBox" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="8" FontSize="14" KeyDown="InputBox_KeyDown" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" x:Name="SendButton" Content="Send" Click="Send_Click" Background="#238636" Foreground="White" BorderBrush="{StaticResource BorderColor}" Margin="8,0,0,0" FontWeight="Bold"/>
            </Grid>
        </Grid>
    </Grid>
</Window>